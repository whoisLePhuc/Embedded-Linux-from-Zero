#===============================================================================
# Embedded Sensor Application Configuration
#===============================================================================

# Application Info
APP_NAME="EmbeddedSensor"
APP_VERSION="2.1.0"
APP_DESCRIPTION="Temperature and humidity sensor daemon"

# Logging
LOG_LEVEL="DEBUG"
LOG_DIR="/var/log/sensor"
LOG_FILE="${LOG_DIR}/${APP_NAME}.log"
LOG_MAX_SIZE="10485760"
LOG_MAX_FILES="5"

# Data Storage
DATA_DIR="/data/sensor"
DATA_FILE="${DATA_DIR}/readings.db"
DATA_BACKUP_DIR="${DATA_DIR}/backup"

# Sensor Configuration
SENSOR_TYPE="BME280"
I2C_BUS="1"
I2C_ADDRESS="0x48"
SPI_SPEED="1000000"
UART_BAUD="115200"
UART_DEVICE="/dev/ttyAMA0"

# Sampling
SAMPLE_RATE="100"
MAX_BUFFER_SIZE="4096"
OVERSAMPLING="16"

# Network
MQTT_BROKER="mqtt.local"
MQTT_PORT="1883"
MQTT_TOPIC="sensors/temperature"
MQTT_INTERVAL="60"

# Feature Flags
ENABLE_DEBUG="1"
ENABLE_TELEMETRY="0"
ENABLE_REMOTE_CONFIG="1"
ENABLE_WATCHDOG="1"

# Performance
CPU_AFFINITY="0,1"
SCHED_PRIORITY="99"
SCHED_POLICY="SCHED_FIFO"

# Paths (cross-compilation)
CROSS_COMPILE="arm-linux-gnueabihf-"
ARCH="arm"
SYSROOT="/opt/arm-sysroot"
